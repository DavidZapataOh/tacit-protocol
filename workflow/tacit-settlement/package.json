{
	"name": "tacit-settlement",
	"version": "1.0.0",
	"main": "dist/main.js",
	"private": true,
	"scripts": {
		"postinstall": "bun x cre-setup",
		"typecheck": "bun x tsc --noEmit",
		"simulate": "cd .. && cre workflow simulate ./tacit-settlement -T local-simulation -e .env",
		"simulate:testnet": "cd .. && cre workflow simulate ./tacit-settlement -T testnet -e .env",
		"simulate:tx": "cd .. && cre workflow simulate ./tacit-settlement -T local-simulation -e .env --non-interactive --trigger-index 0 --evm-event-index 0 --evm-tx-hash",
		"simulate:run": "bash ../scripts/run-simulation.sh",
		"trade:happy": "bash ../scripts/create-test-trade.sh happy",
		"trade:mismatch": "bash ../scripts/create-test-trade.sh mismatch",
		"trade:sanctions": "bash ../scripts/create-test-trade.sh sanctions",
		"secrets:upload": "cd .. && cre secrets upload -e .env",
		"secrets:list": "cd .. && cre secrets list -e .env"
	},
	"license": "UNLICENSED",
	"dependencies": {
		"@chainlink/cre-sdk": "^1.1.3",
		"viem": "^2.34.0",
		"zod": "^3.25.76"
	},
	"devDependencies": {
		"@types/bun": "1.3.8"
	}
}
