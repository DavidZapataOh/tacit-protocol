# WalletConnect Project ID (get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Chain RPC URLs (optional, RainbowKit provides defaults)
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
NEXT_PUBLIC_ARBITRUM_SEPOLIA_RPC_URL=https://arb-sepolia.g.alchemy.com/v2/YOUR_KEY

# Settlement API (server-side only — NEVER prefix with NEXT_PUBLIC_)
# Deployer private key for on-chain settlement writes
DEPLOYER_PRIVATE_KEY=0x_your_deployer_private_key
# RPC URL for settlement transactions (optional, falls back to public node)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# Set to "true" when CRE DON deployment is active (disables API route settlement)
# NEXT_PUBLIC_CRE_LIVE=true
